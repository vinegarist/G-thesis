{
    "latex-workshop.latex.recipes": [
        {
            "name": "XeLaTeX -> Biber -> XeLaTeX*2",
            "tools": [
                "xelatex",
                "biber",
                "xelatex",
                "xelatex",
                "clean"
            ]
        },
        {
            "name": "XeLaTeX (quick)",
            "tools": [
                "xelatex"
            ]
        }
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "xelatex",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "main"
            ],
            "env": {}
        },
        {
            "name": "biber",
            "command": "biber",
            "args": [
                "main"
            ],
            "env": {}
        },
        {
            "name": "clean",
            "command": "cmd",
            "args": [
                "/c",
                "del /q *.aux *.out *.blg *.toc *.bbl *.bcf *.log *.fls *.fdb_latexmk *.synctex.gz 2>nul"
            ],
            "env": {}
        }
    ],
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.clean.fileTypes": [
        "*.aux",
        "*.bbl",
        "*.blg",
        "*.idx",
        "*.ind",
        "*.lof",
        "*.lot",
        "*.out",
        "*.toc",
        "*.acn",
        "*.acr",
        "*.alg",
        "*.glg",
        "*.glo",
        "*.gls",
        "*.fls",
        "*.log",
        "*.fdb_latexmk",
        "*.synctex.gz",
        "*.bcf",
        "*.run.xml"
    ]
}
